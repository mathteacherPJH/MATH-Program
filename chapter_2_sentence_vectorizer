<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>다중 문장 벡터 변환기 (One-Hot & Frequency)</title>
    <style>
        :root {
            --c-bg-main: #FBF9F4; 
            --c-bg-card: rgba(255, 255, 255, 0.73); 
            --c-text-main: #2C2A29;
            --c-text-muted: #7D7569;
            --c-border: rgba(44, 42, 41, 0.1);
            --c-accent: #2383E2;
            --c-accent-hover: #1A6CB8;
            --c-brand-green: #1B4332;
            --c-brand-green-hover: #123024;
            --c-tag-bg: #E8F5E9;
            --c-tag-text: #2E7D32;
            --c-removed-bg: #FFEBEE;
            --c-removed-text: #C62828;
            --c-vector-bg: #E3F2FD;
            --c-vector-text: #0D47A1;
            --c-tab-bg: #F4F1EA;
        }

        body {
            font-family: 'Malgun Gothic', -apple-system, sans-serif;
            background-color: var(--c-bg-main);
            color: var(--c-text-main);
            margin: 0;
            padding: 24px;
            padding-top: 85px; 
            display: flex;
            flex-direction: column;
            align-items: center;
            letter-spacing: 0.03em;
            position: relative;
            height: 100vh;
            box-sizing: border-box;
            overflow: hidden;
        }

        #neural-canvas {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1;
            pointer-events: none;
        }

        /* 상단 네비게이션 바 */
        .top-navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: rgba(251, 249, 244, 0.85);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--c-border);
            z-index: 1000;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-sizing: border-box;
        }

        .back-btn {
            background: transparent;
            border: none;
            color: var(--c-brand-green);
            font-family: "Consolas", monospace;
            font-size: 13px;
            font-weight: 900;
            letter-spacing: 0.15em;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 8px;
            transition: all 0.2s ease;
        }
        .back-btn:hover {
            transform: translateX(-3px);
            opacity: 0.8;
        }

        .navbar-brand-text {
            font-size: 13px; 
            font-weight: bold; 
            color: var(--c-brand-green); 
            letter-spacing: 0.15em; 
            text-transform: uppercase; 
        }

        /* 메인 레이아웃 */
        .main-layout {
            display: flex;
            width: 100%; 
            height: calc(100vh - 110px); 
            gap: 20px;
            position: relative;
            z-index: 10;
            box-sizing: border-box;
        }

        .card {
            background-color: var(--c-bg-card);
            border: 1px solid var(--c-border);
            border-radius: 12px;
            padding: 24px;
            box-sizing: border-box;
            backdrop-filter: blur(6px);
            box-shadow: 0 10px 30px rgba(44, 42, 41, 0.03);
            display: flex;
            flex-direction: column;
        }

        /* 왼쪽 섹션: 가변형 다중 입력창 */
        .left-panel {
            flex: 1.2; 
            height: 100%;
        }

        .panel-title {
            margin: 0 0 12px 0;
            font-size: 16px;
            color: var(--c-brand-green);
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .input-controls {
            display: flex;
            gap: 6px;
        }

        .control-btn {
            padding: 4px 10px;
            font-size: 12px;
            font-weight: bold;
            border: 1px solid var(--c-border);
            background: white;
            border-radius: 4px;
            cursor: pointer;
            color: var(--c-text-main);
            transition: all 0.2s;
        }
        .control-btn:hover:not(:disabled) {
            background: #eee;
        }
        .control-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .textarea-list {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 16px;
            padding-right: 4px;
        }

        .textarea-wrapper {
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .textarea-wrapper span {
            font-size: 11px;
            color: var(--c-text-muted);
            margin-bottom: 4px;
            font-weight: bold;
        }

        .textarea-wrapper .char-counter {
            position: absolute;
            bottom: 6px;
            right: 12px;
            font-size: 11px;
            color: var(--c-text-muted);
            pointer-events: none;
        }

        textarea {
            width: 100%;
            height: 70px;
            padding: 10px 12px;
            padding-bottom: 22px;
            box-sizing: border-box;
            border: 1px solid var(--c-border);
            border-radius: 8px;
            resize: none;
            font-family: inherit;
            font-size: 14px;
            line-height: 1.5;
            background-color: rgba(255, 255, 255, 0.8);
            color: var(--c-text-main);
            outline: none;
            transition: border-color 0.2s;
        }
        textarea:focus {
            border-color: var(--c-brand-green);
        }

        .run-btn {
            width: 100%;
            padding: 14px 20px;
            background-color: var(--c-brand-green);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: background-color 0.2s;
            letter-spacing: 0.05em;
            box-shadow: 0 4px 12px rgba(27, 67, 50, 0.15);
            flex-shrink: 0;
        }
        .run-btn:hover {
            background-color: var(--c-brand-green-hover);
        }

        /* 오른쪽 섹션 */
        .right-panel {
            flex: 2;
            height: 100%;
            overflow: hidden;
            gap: 14px;
        }

        .nav-group {
            display: flex;
            gap: 4px;
            background: var(--c-tab-bg); 
            padding: 4px;
            border-radius: 8px;
            border: 1px solid rgba(44, 42, 41, 0.05);
            flex-shrink: 0;
        }
        .nav-btn {
            flex: 1;
            border: none;
            background: transparent;
            padding: 8px 4px;
            font-size: 12px;
            font-weight: bold;
            color: var(--c-text-muted);
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.2s;
            white-space: nowrap;
            text-align: center;
        }
        .nav-btn.active {
            background: #FFFFFF;
            color: var(--c-brand-green); 
            box-shadow: 0 2px 6px rgba(44,42,41,0.08);
        }

        .right-panel-content {
            width: 100%;
            height: 100%;
            overflow-y: auto; 
            display: flex;
            flex-direction: column;
            gap: 18px;
            padding-right: 6px; 
            box-sizing: border-box;
        }

        .result-section {
            display: flex;
            flex-direction: column;
            width: 100%;
            box-sizing: border-box;
        }
        .result-section.hidden {
            display: none !important;
        }
        .result-section h3 {
            margin: 0 0 8px 4px;
            font-size: 14px;
            color: var(--c-text-muted);
            font-weight: bold;
        }

        .result-box { 
            background-color: rgba(244, 241, 234, 0.6); 
            padding: 14px; 
            border-radius: 8px; 
            min-height: 48px; 
            display: flex; 
            flex-wrap: wrap; 
            justify-content: flex-start;
            gap: 8px; 
            align-items: center;
            border: 1px solid var(--c-border);
            box-sizing: border-box;
            width: 100%; 
        }

        .vector-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
            width: 100%;
        }

        .vector-row {
            background: rgba(255, 255, 255, 0.6);
            border: 1px solid var(--c-border);
            border-radius: 6px;
            padding: 10px 12px;
        }

        .vector-row .sentence-summary {
            font-size: 12px;
            font-weight: bold;
            color: var(--c-brand-green);
            margin-bottom: 6px;
        }

        .vector-display {
            font-family: 'Consolas', monospace;
            font-size: 13px;
            background: #fff;
            padding: 6px 10px;
            border-radius: 4px;
            border: 1px solid rgba(44, 42, 41, 0.05);
            color: var(--c-vector-text);
            word-break: break-all;
        }
        
        /* 토큰 태그 스타일 */
        .header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            flex-wrap: wrap;
            gap: 10px;
            width: 100%;
            box-sizing: border-box;
        }
        
        .add-section { display: flex; gap: 6px; align-items: center; }
        .add-input {
            padding: 6px 10px;
            border: 1px solid var(--c-border);
            border-radius: 4px;
            width: 120px;
            font-size: 13px;
            outline: none;
            background: white;
        }
        .add-input:focus { border-color: var(--c-accent); }
        .add-btn {
            padding: 6px 12px;
            background-color: var(--c-accent);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
            font-weight: bold;
        }
        .add-btn:hover { background-color: var(--c-accent-hover); }

        .editable-tag { 
            display: inline-flex; 
            align-items: center; 
            justify-content: space-between;
            background-color: var(--c-tag-bg); 
            color: var(--c-tag-text); 
            padding: 4px 8px; 
            border-radius: 4px; 
            font-size: 13px; 
            border: 1px solid rgba(165, 214, 167, 0.6); 
            box-sizing: border-box;
            width: calc(25% - 6px); 
            min-width: 104px;
        }
        .editable-tag input { 
            border: none; 
            background: transparent; 
            color: var(--c-tag-text); 
            font-size: 13px; 
            font-family: inherit; 
            width: 100%;
            text-align: center; 
            font-weight: bold; 
        }
        .editable-tag input:focus {
            outline: none;
            background-color: #fff;
            border-radius: 2px;
        }
        .delete-btn {
            margin-left: 4px;
            cursor: pointer;
            color: var(--c-removed-text);
            font-weight: bold;
            font-size: 14px;
            flex-shrink: 0;
            line-height: 1;
        }

        .right-panel-content::-webkit-scrollbar,
        .textarea-list::-webkit-scrollbar {
            width: 6px;
        }
        .right-panel-content::-webkit-scrollbar-track,
        .textarea-list::-webkit-scrollbar-track {
            background: transparent;
        }
        .right-panel-content::-webkit-scrollbar-thumb,
        .textarea-list::-webkit-scrollbar-thumb {
            background: rgba(44, 42, 41, 0.15);
            border-radius: 3px;
        }
    </style>
</head>
<body>

<canvas id="neural-canvas"></canvas>

<nav class="top-navbar">
    <button onclick="history.back()" class="back-btn">← BACK</button>
    <div class="navbar-brand-text">SENTENCE VECTORIZER</div>
</nav>

<div class="main-layout">
    <!-- 왼쪽: 멀티 문장 입력 칸 -->
    <div class="card left-panel">
        <div class="panel-title">
            <span>분석 문장 입력 (최대 100자)</span>
            <div class="input-controls">
                <button class="control-btn" id="removeInputBtn" onclick="removeInputField()">- 제거</button>
                <button class="control-btn" id="addInputBtn" onclick="addInputField()">+ 추가</button>
            </div>
        </div>
        <div class="textarea-list" id="textareaList">
            <!-- 기본 3개 구성 -->
            <div class="textarea-wrapper" id="wrapper_0">
                <span>문장 1</span>
                <textarea id="input_0" maxlength="100" oninput="updateCharCount(0)" placeholder="첫 번째 문장을 입력하세요."></textarea>
                <div class="char-counter" id="counter_0">0/100</div>
            </div>
            <div class="textarea-wrapper" id="wrapper_1">
                <span>문장 2</span>
                <textarea id="input_1" maxlength="100" oninput="updateCharCount(1)" placeholder="두 번째 문장을 입력하세요."></textarea>
                <div class="char-counter" id="counter_1">0/100</div>
            </div>
            <div class="textarea-wrapper" id="wrapper_2">
                <span>문장 3</span>
                <textarea id="input_2" maxlength="100" oninput="updateCharCount(2)" placeholder="세 번째 문장을 입력하세요."></textarea>
                <div class="char-counter" id="counter_2">0/100</div>
            </div>
        </div>
        <button class="run-btn" onclick="processNLP()">단어집합 구성 및 벡터 변환 ⚡</button>
    </div>

    <!-- 오른쪽: 결과 제어판 -->
    <div class="card right-panel">
        <div class="nav-group">
            <button id="tab_all" class="nav-btn active" onclick="switchTab('all')">전체보기</button>
            <button id="tab_1" class="nav-btn" onclick="switchTab('1')">1. 단어 집합(사전)</button>
            <button id="tab_2" class="nav-btn" onclick="switchTab('2')">2. 원-핫 벡터</button>
            <button id="tab_3" class="nav-btn" onclick="switchTab('3')">3. 빈도수 벡터</button>
        </div>

        <div class="right-panel-content">
            <!-- 1. 단어 집합 편집기 -->
            <div id="sec_1" class="result-section">
                <div class="header-flex">
                    <h3>1. 단어집합(Vocabulary) 및 사용자 분석 수정</h3>
                    <div class="add-section">
                        <input type="text" id="newWordInput" class="add-input" placeholder="새 단어 입력">
                        <button class="add-btn" onclick="addToken()">추가</button>
                    </div>
                </div>
                <div class="result-box" id="vocabContainer">분석을 실행하면 단어집합이 구성됩니다.</div>
            </div>

            <!-- 2. 원-핫 벡터 결과 -->
            <div id="sec_2" class="result-section">
                <h3>2. 원-핫 인코딩 벡터 (One-Hot Vector)</h3>
                <div class="result-box" style="display:block;">
                    <div class="vector-container" id="oneHotContainer">문장별 원-핫 벡터가 여기에 출력됩니다.</div>
                </div>
            </div>

            <!-- 3. 빈도수 벡터 결과 -->
            <div id="sec_3" class="result-section">
                <h3>3. 빈도수 벡터 (Frequency Vector / Term Frequency)</h3>
                <div class="result-box" style="display:block;">
                    <div class="vector-container" id="freqContainer">문장별 단어 빈도 벡터가 여기에 출력됩니다.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let inputCount = 3;
const MIN_INPUTS = 3;
const MAX_INPUTS = 10;
let vocabulary = []; // 최종 구축 단어집합 리스트

function updateCharCount(index) {
    const textarea = document.getElementById(`input_${index}`);
    const counter = document.getElementById(`counter_${index}`);
    counter.innerText = `${textarea.value.length}/100`;
}

function addInputField() {
    if (inputCount >= MAX_INPUTS) return;
    
    const container = document.getElementById("textareaList");
    const wrapper = document.createElement("div");
    wrapper.className = "textarea-wrapper";
    wrapper.id = `wrapper_${inputCount}`;
    
    wrapper.innerHTML = `
        <span>문장 ${inputCount + 1}</span>
        <textarea id="input_${inputCount}" maxlength="100" oninput="updateCharCount(${inputCount})" placeholder="문장을 입력하세요."></textarea>
        <div class="char-counter" id="counter_${inputCount}">0/100</div>
    `;
    
    container.appendChild(wrapper);
    inputCount++;
    updateControlButtons();
    container.scrollTop = container.scrollHeight;
}

function removeInputField() {
    if (inputCount <= MIN_INPUTS) return;
    
    inputCount--;
    const wrapper = document.getElementById(`wrapper_${inputCount}`);
    wrapper.remove();
    updateControlButtons();
}

function updateControlButtons() {
    document.getElementById("addInputBtn").disabled = (inputCount >= MAX_INPUTS);
    document.getElementById("removeInputBtn").disabled = (inputCount <= MIN_INPUTS);
}

function switchTab(tabId) {
    const tabs = ['all', '1', '2', '3'];
    tabs.forEach(t => {
        document.getElementById(`tab_${t}`).classList.remove('active');
        if(t !== 'all') document.getElementById(`sec_${t}`).classList.add('hidden');
    });

    document.getElementById(`tab_${tabId}`).classList.add('active');
    if (tabId === 'all') {
        tabs.forEach(t => {
            if(t !== 'all') document.getElementById(`sec_${t}`).classList.remove('hidden');
        });
    } else {
        document.getElementById(`sec_${tabId}`).classList.remove('hidden');
    }
}

// 한국어 기본 형태 분석 및 조사 기초 분리 로직
const stopwords = new Set(["은", "는", "이", "가", "을", "를", "의", "에", "에서", "에게", "과", "와", "도", "만", "으로", "로"]);

function tokenize(text) {
    // 구두점 제거 및 공백 분할
    const words = text.replace(/[.,\/#!$%\^&\*;:{}=\-_`~()]/g, "").split(/\s+/);
    const tokens = new Set();

    words.forEach(word => {
        if (!word) return;
        
        // 조사 간단 분리 매칭
        const josaRegex = /(은|는|이|가|을|를|의|에|에서|에게|과|와|도|만|으로|로)$/;
        const match = word.match(josaRegex);
        
        if (match && word.length > match[0].length) {
            const stem = word.replace(josaRegex, "");
            tokens.add(stem);
        } else {
            tokens.add(word);
        }
    });
    return Array.from(tokens);
}

// 메인 분석 및 변환 허브
function processNLP() {
    const textFields = [];
    for(let i=0; i<inputCount; i++) {
        const val = document.getElementById(`input_${i}`).value.trim();
        if(val) textFields.push(val);
    }

    if (textFields.length === 0) {
        alert("최소 한 개 이상의 문장을 입력해주세요!");
        return;
    }

    // 1단계: 전체 문장을 돌며 유니크 단어 집합(Vocabulary) 생성
    const globalVocabSet = new Set();
    textFields.forEach(sentence => {
        const tokens = tokenize(sentence);
        tokens.forEach(t => globalVocabSet.add(t));
    });

    vocabulary = Array.from(globalVocabSet);
    
    // 화면 갱신
    renderVocabEditor();
    calculateVectors();
}

// 단어집합 UI 렌더링 (사용자가 수정/삭제 가능하도록 구성)
function renderVocabEditor() {
    const container = document.getElementById("vocabContainer");
    if (vocabulary.length === 0) {
        container.innerHTML = "단어 집합이 비어있습니다.";
        return;
    }

    let html = "";
    vocabulary.forEach((word, index) => {
        html += `
            <span class="editable-tag">
                <input type="text" value="${word}" onchange="updateVocab(${index}, this.value)">
                <span class="delete-btn" onclick="deleteVocab(${index})">×</span>
            </span>
        `;
    });
    container.innerHTML = html;
}

function updateVocab(index, newValue) {
    const cleanValue = newValue.trim();
    if(cleanValue) {
        vocabulary[index] = cleanValue;
        calculateVectors(); // 사전이 바뀌면 벡터 재계산
    }
}

function deleteVocab(index) {
    vocabulary.splice(index, 1);
    renderVocabEditor();
    calculateVectors();
}

function addToken() {
    const input = document.getElementById("newWordInput");
    const value = input.value.trim();
    if (!value) {
        alert("추가할 단어를 입력하세요!");
        return;
    }
    if (!vocabulary.includes(value)) {
        vocabulary.push(value);
        renderVocabEditor();
        calculateVectors();
    }
    input.value = "";
}

// 원-핫 벡터 및 빈도수 벡터 연산 및 출력
function calculateVectors() {
    const oneHotContainer = document.getElementById("oneHotContainer");
    const freqContainer = document.getElementById("freqContainer");
    
    oneHotContainer.innerHTML = "";
    freqContainer.innerHTML = "";

    if(vocabulary.length === 0) {
        oneHotContainer.innerHTML = "단어 집합이 비어있어 벡터를 생성할 수 없습니다.";
        freqContainer.innerHTML = "단어 집합이 비어있어 벡터를 생성할 수 없습니다.";
        return;
    }

    let validSentenceIndex = 1;

    for(let i=0; i<inputCount; i++) {
        const sentence = document.getElementById(`input_${i}`).value.trim();
        if(!sentence) continue; // 비어있는 입력창은 건너뜀

        const tokens = tokenize(sentence);

        // 1. 빈도수 벡터(TF Vector) 연산
        const freqVector = new Array(vocabulary.length).fill(0);
        tokens.forEach(token => {
            const vocabIdx = vocabulary.indexOf(token);
            if(vocabIdx !== -1) {
                freqVector[vocabIdx]++;
            }
        });

        // 2. 원-핫 인코딩 시퀀스 연산
        // 이론상 자연어처리(NLP)의 다중 단어 원-핫은 모든 해당 위치를 1로 켜는 멀티-핫 형식이 되거나, 
        // 문장 내 각 단어를 순서대로 원-핫 임베딩 리스트로 표현합니다. 
        // 여기서는 직관성을 위해 사전 매칭 위치에 존재 유무(1 또는 0)로 매핑된 바이너리 벡터를 출력합니다.
        const oneHotVector = freqVector.map(count => count > 0 ? 1 : 0);

        // UI 출력 요소 생성
        const oneHotRow = document.createElement("div");
        oneHotRow.className = "vector-row";
        oneHotRow.innerHTML = `
            <div class="sentence-summary">문장 ${validSentenceIndex} : "${sentence}"</div>
            <div class="vector-display">[ ${oneHotVector.join(", ")} ]</div>
        `;
        oneHotContainer.appendChild(oneHotRow);

        const freqRow = document.createElement("div");
        freqRow.className = "vector-row";
        freqRow.innerHTML = `
            <div class="sentence-summary">문장 ${validSentenceIndex} : "${sentence}"</div>
            <div class="vector-display">[ ${freqVector.join(", ")} ]</div>
        `;
        freqContainer.appendChild(freqRow);

        validSentenceIndex++;
    }
}

// 배경 입자 신경망 애니메이션 코드 유지
const bgCanvas = document.getElementById('neural-canvas');
const bgCtx = bgCanvas.getContext('2d');
let particles = [];
const mouse = { x: null, y: null, radius: 150 };

function resizeBgCanvas() {
    bgCanvas.width = window.innerWidth;
    bgCanvas.height = window.innerHeight;
    initParticles();
}

class Particle {
    constructor() {
        this.x = Math.random() * bgCanvas.width;
        this.y = Math.random() * bgCanvas.height;
        this.vx = (Math.random() - 0.5) * 0.35;
        this.vy = (Math.random() - 0.5) * 0.35;
        this.radius = Math.random() * 2 + 1.5; 
    }
    update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > bgCanvas.width) this.vx *= -1;
        if (this.y < 0 || this.y > bgCanvas.height) this.vy *= -1;

        let dx = mouse.x - this.x;
        let dy = mouse.y - this.y;
        let distance = Math.sqrt(dx * dx + dy * dy);
        if (distance < mouse.radius) {
            const force = (mouse.radius - distance) / mouse.radius;
            this.x -= dx * force * 0.03;
            this.y -= dy * force * 0.03;
        }
    }
    draw() {
        bgCtx.beginPath();
        bgCtx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        bgCtx.fillStyle = 'rgba(27, 67, 50, 0.15)'; 
        bgCtx.fill();
    }
}

function initParticles() {
    particles = [];
    const particleCount = Math.floor((bgCanvas.width * bgCanvas.height) / 9000);
    for (let i = 0; i < particleCount; i++) {
        particles.push(new Particle());
    }
}

function animateBg() {
    bgCtx.clearRect(0, 0, bgCanvas.width, bgCanvas.height);
    for (let i = 0; i < particles.length; i++) {
        particles[i].update();
        particles[i].draw();

        for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < 110) {
                bgCtx.beginPath();
                bgCtx.moveTo(particles[i].x, particles[i].y);
                bgCtx.lineTo(particles[j].x, particles[j].y);
                bgCtx.strokeStyle = `rgba(27, 67, 50, ${0.08 * (1 - dist / 110)})`;
                bgCtx.lineWidth = 1.0;
                bgCtx.stroke();
            }
        }
    }
    requestAnimationFrame(animateBg);
}

window.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
window.addEventListener('mouseout', () => { mouse.x = null; mouse.y = null; });
window.addEventListener('resize', resizeBgCanvas);

window.addEventListener('DOMContentLoaded', () => {
    resizeBgCanvas();
    animateBg();
    updateControlButtons();
});
</script>

