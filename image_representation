<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>이미지 데이터의 표현</title>
    <style>
        /* 기본 스타일 초기화 및 PyQt6 인터페이스 느낌 재현 */
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            font-size: 12px;
            background-color: #f0f0f0;
            margin: 0;
            padding: 5px;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            user-select: none;
        }

        /* 전체 고정 크기 컨테이너 */
        .app-container {
            width: 520px;
            height: 220px;
            background: #f0f0f0;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
        }

        /* 탭 내비게이션 */
        .tab-header {
            display: flex;
            border-bottom: 1px solid #c0c0c0;
            background: #e1e1e1;
        }
        .tab-btn {
            padding: 6px 16px;
            border: 1px solid transparent;
            border-bottom: none;
            background: transparent;
            font-size: 12px;
            cursor: pointer;
            outline: none;
            margin-bottom: -1px;
        }
        .tab-btn.active {
            background: #f0f0f0;
            border-color: #c0c0c0;
            border-top-left-radius: 2px;
            border-top-right-radius: 2px;
            font-weight: bold;
        }

        /* 탭 콘텐츠 영역 */
        .tab-content {
            flex: 1;
            display: none;
            background: #f0f0f0;
        }
        .tab-content.active {
            display: flex;
        }

        /* 1번 탭: RGB 색상 확인 */
        .rgb-tab-inner {
            width: 100%;
            padding: 20px 25px;
            display: flex;
            align-items: center;
            gap: 25px;
            box-sizing: border-box;
        }
        .preview-box {
            width: 130px;
            height: 130px;
            background-color: #FFFFFF;
            border: 1px solid #000;
            flex-shrink: 0;
        }
        .rgb-controls {
            flex: 1;
            display: grid;
            grid-template-columns: auto 1fr auto;
            align-items: center;
            row-gap: 8px;
            column-gap: 8px;
        }
        .rgb-label {
            width: 20px;
        }
        .rgb-slider {
            width: 100%;
            margin: 0;
            cursor: pointer;
        }
        
        /* 커스텀 숫자 증감 컨테이너 */
        .spin-container {
            display: flex;
            align-items: center;
        }
        .num-input {
            width: 45px;
            height: 20px;
            text-align: center;
            font-weight: bold;
            border: 1px solid #B0B0B0;
            background-color: white;
            box-sizing: border-box;
            outline: none;
        }
        .spin-btns {
            display: flex;
            flex-direction: column;
            margin-left: 1px;
        }
        .spin-btn {
            width: 19px;
            height: 10px;
            font-size: 6px;
            line-height: 8px;
            text-align: center;
            border: 1px solid #C0C0C0;
            background-color: #EFEFEF;
            cursor: pointer;
            outline: none;
            padding: 0;
        }
        .spin-btn:active { background-color: #dcdcdc; }
        .spin-btn.down { margin-top: 0px; }

        /* Hex 및 스포이드 레이아웃 */
        .hex-row {
            grid-column: span 3;
            display: flex;
            align-items: center;
            margin-top: 5px;
        }
        .hex-label { width: 30px; }
        .hex-value { font-weight: bold; font-size: 13px; }
        .dropper-btn {
            margin-left: auto;
            width: 85px;
            height: 26px;
            background: #e1e1e1;
            border: 1px solid #acacac;
            border-radius: 2px;
            cursor: pointer;
            font-size: 12px;
        }
        .dropper-btn:active { background: #cbcbcb; }

        /* 2번 탭: 이미지 행렬화 */
        .matrix-tab-inner {
            width: 100%;
            padding: 10px 15px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-sizing: border-box;
            justify-content: center;
        }
        .matrix-left-grid {
            display: grid;
            grid-template-columns: repeat(2, 65px);
            grid-template-rows: repeat(2, 65px);
            gap: 4px;
        }
        .matrix-cell {
            width: 65px;
            height: 65px;
            background-color: #FFFFFF;
            border: 1px solid #000;
        }
        .matrix-right-grid {
            display: grid;
            grid-template-columns: repeat(2, 165px);
            grid-template-rows: repeat(2, 65px);
            gap: 6px;
        }
        .matrix-input-container {
            width: 165px;
            height: 65px;
            border: 1px solid #C0C0C0;
            border-radius: 2px;
            background-color: #FAFAFA;
            box-sizing: border-box;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 4px;
        }
        .matrix-sub-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }
        .matrix-num-input {
            width: 40px;
            height: 20px;
            text-align: center;
            font-weight: bold;
            border: 1px solid #B0B0B0;
            background-color: white;
            box-sizing: border-box;
            outline: none;
        }
        .matrix-num-input.r { color: red; }
        .matrix-num-input.g { color: green; }
        .matrix-num-input.b { color: blue; }
        .matrix-spin-btns {
            display: flex;
            gap: 2px;
        }
        .matrix-spin-btn {
            width: 19px;
            height: 14px;
            font-size: 7px;
            line-height: 12px;
            text-align: center;
            border: 1px solid #C0C0C0;
            background-color: #EFEFEF;
            cursor: pointer;
            padding: 0;
        }
        .matrix-spin-btn:active { background-color: #dcdcdc; }
    </style>
</head>
<body>

<div class="app-container">
    <div class="tab-header">
        <button class="tab-btn active" onclick="switchTab(event, 'rgb-tab')">RGB 색상 확인</button>
        <button class="tab-btn" onclick="switchTab(event, 'matrix-tab')">이미지 행렬화</button>
    </div>

    <div id="rgb-tab" class="tab-content active">
        <div class="rgb-tab-inner">
            <div id="previewBox" class="preview-box"></div>
            <div class="rgb-controls">
                <div class="rgb-label">R:</div>
                <input type="range" id="rSlider" class="rgb-slider" min="0" max="255" value="255">
                <div class="spin-container">
                    <input type="text" id="rEdit" class="num-input" value="255">
                    <div class="spin-btns">
                        <button class="spin-btn" onclick="stepRgb('r', 1)">▲</button>
                        <button class="spin-btn down" onclick="stepRgb('r', -1)">▼</button>
                    </div>
                </div>

                <div class="rgb-label">G:</div>
                <input type="range" id="gSlider" class="rgb-slider" min="0" max="255" value="255">
                <div class="spin-container">
                    <input type="text" id="gEdit" class="num-input" value="255">
                    <div class="spin-btns">
                        <button class="spin-btn" onclick="stepRgb('g', 1)">▲</button>
                        <button class="spin-btn down" onclick="stepRgb('g', -1)">▼</button>
                    </div>
                </div>

                <div class="rgb-label">B:</div>
                <input type="range" id="bSlider" class="rgb-slider" min="0" max="255" value="255">
                <div class="spin-container">
                    <input type="text" id="bEdit" class="num-input" value="255">
                    <div class="spin-btns">
                        <button class="spin-btn" onclick="stepRgb('b', 1)">▲</button>
                        <button class="spin-btn down" onclick="stepRgb('b', -1)">▼</button>
                    </div>
                </div>

                <div class="hex-row">
                    <div class="hex-label">Hex:</div>
                    <div id="hexValLabel" class="hex-value">#FFFFFF</div>
                    <button id="dropperBtn" class="dropper-btn" onclick="triggerDropper()">스포이드</button>
                </div>
            </div>
        </div>
    </div>

    <div id="matrix-tab" class="tab-content">
        <div class="matrix-tab-inner">
            <div class="matrix-left-grid">
                <div id="cell_0_0" class="matrix-cell"></div>
                <div id="cell_0_1" class="matrix-cell"></div>
                <div id="cell_1_0" class="matrix-cell"></div>
                <div id="cell_1_1" class="matrix-cell"></div>
            </div>
            
            <div class="matrix-right-grid">
                <div class="matrix-input-container">
                    <div class="matrix-sub-item">
                        <input type="text" id="m_0_0_r" class="matrix-num-input r" value="255" oninput="updateMatrixCell(0,0)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,0,'r',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,0,'r',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_0_0_g" class="matrix-num-input g" value="255" oninput="updateMatrixCell(0,0)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,0,'g',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,0,'g',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_0_0_b" class="matrix-num-input b" value="255" oninput="updateMatrixCell(0,0)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,0,'b',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,0,'b',-1)">▼</button>
                        </div>
                    </div>
                </div>
                <div class="matrix-input-container">
                    <div class="matrix-sub-item">
                        <input type="text" id="m_0_1_r" class="matrix-num-input r" value="255" oninput="updateMatrixCell(0,1)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,1,'r',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,1,'r',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_0_1_g" class="matrix-num-input g" value="255" oninput="updateMatrixCell(0,1)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,1,'g',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,1,'g',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_0_1_b" class="matrix-num-input b" value="255" oninput="updateMatrixCell(0,1)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,1,'b',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(0,1,'b',-1)">▼</button>
                        </div>
                    </div>
                </div>
                <div class="matrix-input-container">
                    <div class="matrix-sub-item">
                        <input type="text" id="m_1_0_r" class="matrix-num-input r" value="255" oninput="updateMatrixCell(1,0)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,0,'r',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,0,'r',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_1_0_g" class="matrix-num-input g" value="255" oninput="updateMatrixCell(1,0)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,0,'g',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,0,'g',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_1_0_b" class="matrix-num-input b" value="255" oninput="updateMatrixCell(1,0)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,0,'b',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,0,'b',-1)">▼</button>
                        </div>
                    </div>
                </div>
                <div class="matrix-input-container">
                    <div class="matrix-sub-item">
                        <input type="text" id="m_1_1_r" class="matrix-num-input r" value="255" oninput="updateMatrixCell(1,1)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,1,'r',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,1,'r',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_1_1_g" class="matrix-num-input g" value="255" oninput="updateMatrixCell(1,1)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,1,'g',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,1,'g',-1)">▼</button>
                        </div>
                    </div>
                    <div class="matrix-sub-item">
                        <input type="text" id="m_1_1_b" class="matrix-num-input b" value="255" oninput="updateMatrixCell(1,1)">
                        <div class="matrix-spin-btns">
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,1,'b',1)">▲</button>
                            <button class="matrix-spin-btn" onclick="stepMatrix(1,1,'b',-1)">▼</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // ------------------ 탭 전환 로직 ------------------
    function switchTab(evt, tabId) {
        const tabContents = document.querySelectorAll('.tab-content');
        tabContents.forEach(content => content.classList.remove('active'));

        const tabButtons = document.querySelectorAll('.tab-btn');
        tabButtons.forEach(btn => btn.classList.remove('active'));

        document.getElementById(tabId).classList.add('active');
        evt.currentTarget.classList.add('active');
    }

    // ------------------ 헬퍼 함수 ------------------
    function clamp(val) {
        return Math.max(0, Math.min(255, val));
    }
    function componentToHex(c) {
        let hex = c.toString(16).toUpperCase();
        return hex.length == 1 ? "0" + hex : hex;
    }
    function rgbToHex(r, g, b) {
        return "#" + componentToHex(r) + componentToHex(g) + componentToHex(b);
    }

    // ------------------ 탭 1: RGB 색상 로직 ------------------
    const rSlider = document.getElementById('rSlider');
    const gSlider = document.getElementById('gSlider');
    const bSlider = document.getElementById('bSlider');
    const rEdit = document.getElementById('rEdit');
    const gEdit = document.getElementById('gEdit');
    const bEdit = document.getElementById('bEdit');
    const previewBox = document.getElementById('previewBox');
    const hexValLabel = document.getElementById('hexValLabel');

    function updateRgbFromSliders() {
        const r = parseInt(rSlider.value);
        const g = parseInt(gSlider.value);
        const b = parseInt(bSlider.value);
        
        rEdit.value = r;
        gEdit.value = g;
        bEdit.value = b;
        
        const hex = rgbToHex(r, g, b);
        previewBox.style.backgroundColor = hex;
        hexValLabel.innerText = hex;
    }

    function updateRgbFromEdits() {
        let r = parseInt(rEdit.value) || 0;
        let g = parseInt(gEdit.value) || 0;
        let b = parseInt(bEdit.value) || 0;

        r = clamp(r); g = clamp(g); b = clamp(b);

        rSlider.value = r;
        gSlider.value = g;
        bSlider.value = b;

        const hex = rgbToHex(r, g, b);
        previewBox.style.backgroundColor = hex;
        hexValLabel.innerText = hex;
    }

    function stepRgb(channel, amount) {
        const editEl = document.getElementById(`${channel}Edit`);
        let val = parseInt(editEl.value) || 0;
        editEl.value = clamp(val + amount);
        updateRgbFromEdits();
    }

    // 이벤트 리스너 바인딩
    [rSlider, gSlider, bSlider].forEach(slider => slider.addEventListener('input', updateRgbFromSliders));
    [rEdit, gEdit, bEdit].forEach(edit => edit.addEventListener('input', updateRgbFromEdits));


    // 웹 표준 EyeDropper API를 활용한 스포이드 기능
    async function triggerDropper() {
        if (!window.EyeDropper) {
            alert('이 브라우저는 스포이드 기능을 지원하지 않습니다. 크롬, 엣지, 웨일 브라우저를 사용해 주세요.');
            return;
        }
        const dropperBtn = document.getElementById('dropperBtn');
        dropperBtn.innerText = "화면 클릭!";
        
        const eyeDropper = new EyeDropper();
        try {
            const result = await eyeDropper.open();
            // result.sRGBHex 형태로 #RRGGBB 반환됨
            const hex = result.sRGBHex.toUpperCase();
            
            const r = parseInt(hex.substring(1, 3), 16);
            const g = parseInt(hex.substring(3, 5), 16);
            const b = parseInt(hex.substring(5, 7), 16);

            rEdit.value = r;
            gEdit.value = g;
            bEdit.value = b;
            updateRgbFromEdits();
        } catch (e) {
            // 선택을 취소했을 때 처리
        } finally {
            dropperBtn.innerText = "스포이드";
        }
    }

    // ------------------ 탭 2: 이미지 행렬화 로직 ------------------
    function updateMatrixCell(row, col) {
        const rEl = document.getElementById(`m_${row}_${col}_r`);
        const gEl = document.getElementById(`m_${row}_${col}_g`);
        const bEl = document.getElementById(`m_${row}_${col}_b`);

        let r = parseInt(rEl.value) || 0;
        let g = parseInt(gEl.value) || 0;
        let b = parseInt(bEl.value) || 0;

        r = clamp(r); g = clamp(g); b = clamp(b);

        const hex = rgbToHex(r, g, b);
        document.getElementById(`cell_${row}_${col}`).style.backgroundColor = hex;
    }

    function stepMatrix(row, col, channel, amount) {
        const editEl = document.getElementById(`m_${row}_${col}_${channel}`);
        let val = parseInt(editEl.value) || 0;
        editEl.value = clamp(val + amount);
        updateMatrixCell(row, col);
    }

    // 초기 실행 시 화면 세팅 데이터 채우기
    updateRgbFromSliders();
    for(let r=0; r<2; r++){
        for(let c=0; c<2; c++){
            updateMatrixCell(r, c);
        }
    }
</script>

</body>
</html>
